// full_dependencies.dot — ПОЛНЫЙ граф зависимостей проекта MiniJava.
// Узел = класс/модуль. Стрелка A -> B: A зависит от B (через #include).
// Цвет = слой архитектуры (см. легенду). Рендер:
//   dot -Tsvg full_dependencies.dot -o deps.svg
//   dot -Tpng -Gdpi=110 full_dependencies.dot -o deps.png
digraph MiniJavaDeps {
  rankdir=TB;
  ratio=compress;
  nodesep=0.18; ranksep=0.5; splines=true; concentrate=true;
  fontname="Helvetica";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=9, margin="0.08,0.04", height=0.32];
  edge [fontname="Helvetica", fontsize=7, color="#8c96a0", arrowsize=0.6];
  labelloc="t"; fontsize=16;
  label="Полный граф зависимостей MiniJava\nУзел — класс/модуль; стрелка A → B означает «A зависит от B» (#include); цвет — слой архитектуры";
  "main" [fillcolor="#ffe0b2", label="main\nТочка входа: парсинг +\nзапуск", tooltip="Точка входа: парсинг + запуск"];
  "driver" [fillcolor="#ffe0b2", label="driver\nДрайвер: лексер +\nпарсер + визиторы", tooltip="Драйвер: лексер + парсер + визиторы"];
  "scanner" [fillcolor="#ffe0b2", label="scanner\nЛексер (Flex): текст →\nтокены", tooltip="Лексер (Flex): текст → токены"];
  "Elements" [fillcolor="#ffe0b2", label="Elements\nАгрегатор: подключает\nвсе узлы AST", tooltip="Агрегатор: подключает все узлы AST"];
  "ForwardDeclaration" [fillcolor="#ffe0b2", label="ForwardDeclaration\nПредобъявления классов\nAST", tooltip="Предобъявления классов AST"];
  "BaseElement" [fillcolor="#e1bee7", label="BaseElement\nБаза узлов AST\n(location)", tooltip="База узлов AST (location)"];
  "Visitor" [fillcolor="#e1bee7", label="Visitor\nИнтерфейс посетителя", tooltip="Интерфейс посетителя"];
  "SymbolTreeVisitor" [fillcolor="#ffccbc", label="SymbolTreeVisitor\nСемантика: таблица\nсимволов, типы", tooltip="Семантика: таблица символов, типы"];
  "ExecuteVisitor" [fillcolor="#ffccbc", label="ExecuteVisitor\nИнтерпретатор\nпрограммы", tooltip="Интерпретатор программы"];
  "PrintVisitor" [fillcolor="#ffccbc", label="PrintVisitor\nДамп AST в файл", tooltip="Дамп AST в файл"];
  "Program" [fillcolor="#c8e6c9", label="Program\nКорень AST", tooltip="Корень AST"];
  "MainClass" [fillcolor="#c8e6c9", label="MainClass\nГлавный класс (main)", tooltip="Главный класс (main)"];
  "ClassDeclaration" [fillcolor="#c8e6c9", label="ClassDeclaration\nОбъявление класса", tooltip="Объявление класса"];
  "ClassDeclarationList" [fillcolor="#c8e6c9", label="ClassDeclarationList\nСписок классов", tooltip="Список классов"];
  "DeclarationList" [fillcolor="#c8e6c9", label="DeclarationList\nСписок членов класса", tooltip="Список членов класса"];
  "MethodDeclaration" [fillcolor="#c8e6c9", label="MethodDeclaration\nОбъявление метода", tooltip="Объявление метода"];
  "FieldDeclaration" [fillcolor="#c8e6c9", label="FieldDeclaration\nПоле класса", tooltip="Поле класса"];
  "Formal" [fillcolor="#c8e6c9", label="Formal\nПараметр метода", tooltip="Параметр метода"];
  "FormalsList" [fillcolor="#c8e6c9", label="FormalsList\nСписок параметров", tooltip="Список параметров"];
  "Statement" [fillcolor="#bbdefb", label="Statement\nБаза операторов", tooltip="База операторов"];
  "StatementList" [fillcolor="#bbdefb", label="StatementList\nБлок операторов", tooltip="Блок операторов"];
  "VarDeclaration" [fillcolor="#bbdefb", label="VarDeclaration\nБаза объявл.\nпеременной", tooltip="База объявл. переменной"];
  "LocalVarDeclaration" [fillcolor="#bbdefb", label="LocalVarDeclaration\nЛокальная переменная", tooltip="Локальная переменная"];
  "VarAssignment" [fillcolor="#bbdefb", label="VarAssignment\nПрисваивание", tooltip="Присваивание"];
  "IfElse" [fillcolor="#bbdefb", label="IfElse\nif / else", tooltip="if / else"];
  "While" [fillcolor="#bbdefb", label="While\nЦикл while", tooltip="Цикл while"];
  "Print" [fillcolor="#bbdefb", label="Print\nSystem.out.println", tooltip="System.out.println"];
  "Return" [fillcolor="#bbdefb", label="Return\nВозврат из метода", tooltip="Возврат из метода"];
  "Assert" [fillcolor="#bbdefb", label="Assert\nassert", tooltip="assert"];
  "ScopeBlock" [fillcolor="#bbdefb", label="ScopeBlock\nБлок { } (область)", tooltip="Блок { } (область)"];
  "MethodInvocation" [fillcolor="#bbdefb", label="MethodInvocation\nВызов метода", tooltip="Вызов метода"];
  "Expression" [fillcolor="#d7ccc8", label="Expression\nБаза выражений (кеш\nтипа)", tooltip="База выражений (кеш типа)"];
  "ExpressionList" [fillcolor="#d7ccc8", label="ExpressionList\nСписок выражений", tooltip="Список выражений"];
  "IdentExpression" [fillcolor="#d7ccc8", label="IdentExpression\nПеременная", tooltip="Переменная"];
  "NumExpression" [fillcolor="#d7ccc8", label="NumExpression\nЧисло", tooltip="Число"];
  "TrueExpression" [fillcolor="#d7ccc8", label="TrueExpression\ntrue", tooltip="true"];
  "FalseExpression" [fillcolor="#d7ccc8", label="FalseExpression\nfalse", tooltip="false"];
  "ThisExpression" [fillcolor="#d7ccc8", label="ThisExpression\nthis", tooltip="this"];
  "FieldInvokeExpression" [fillcolor="#d7ccc8", label="FieldInvokeExpression\nthis.x — поле", tooltip="this.x — поле"];
  "IndexExpression" [fillcolor="#d7ccc8", label="IndexExpression\narr[i] — индексация", tooltip="arr[i] — индексация"];
  "LengthExpression" [fillcolor="#d7ccc8", label="LengthExpression\narr.length", tooltip="arr.length"];
  "AllocExpression" [fillcolor="#d7ccc8", label="AllocExpression\nnew T[]/new Class()", tooltip="new T[]/new Class()"];
  "NotExpression" [fillcolor="#d7ccc8", label="NotExpression\nОтрицание !", tooltip="Отрицание !"];
  "BinaryExpression" [fillcolor="#d7ccc8", label="BinaryExpression\nБаза бинарных операций", tooltip="База бинарных операций"];
  "ArithmeticExpression" [fillcolor="#d7ccc8", label="ArithmeticExpression\nБаза арифметики", tooltip="База арифметики"];
  "AddExpression" [fillcolor="#d7ccc8", label="AddExpression\n+", tooltip="+"];
  "SubExpression" [fillcolor="#d7ccc8", label="SubExpression\n−", tooltip="−"];
  "MulExpression" [fillcolor="#d7ccc8", label="MulExpression\n×", tooltip="×"];
  "DivExpression" [fillcolor="#d7ccc8", label="DivExpression\n÷", tooltip="÷"];
  "ModExpression" [fillcolor="#d7ccc8", label="ModExpression\n%", tooltip="%"];
  "ComparisonExpression" [fillcolor="#d7ccc8", label="ComparisonExpression\nБаза сравнений", tooltip="База сравнений"];
  "LessExpression" [fillcolor="#d7ccc8", label="LessExpression\n<", tooltip="<"];
  "GreaterExpression" [fillcolor="#d7ccc8", label="GreaterExpression\n>", tooltip=">"];
  "EqualExpression" [fillcolor="#d7ccc8", label="EqualExpression\n==", tooltip="=="];
  "LogicalExpression" [fillcolor="#d7ccc8", label="LogicalExpression\nБаза логических", tooltip="База логических"];
  "LogicalAndExpression" [fillcolor="#d7ccc8", label="LogicalAndExpression\n&&", tooltip="&&"];
  "LogicalOrExpression" [fillcolor="#d7ccc8", label="LogicalOrExpression\n||", tooltip="||"];
  "Type" [fillcolor="#fff9c4", label="Type\nТип\n(int/bool/void/класс,\nмассив)", tooltip="Тип (int/bool/void/класс, массив)"];
  "BaseSymbol" [fillcolor="#fff9c4", label="BaseSymbol\nБаза символов (имя)", tooltip="База символов (имя)"];
  "STClass" [fillcolor="#fff9c4", label="STClass\nСимвол класса", tooltip="Символ класса"];
  "STMethod" [fillcolor="#fff9c4", label="STMethod\nСимвол метода", tooltip="Символ метода"];
  "STVariable" [fillcolor="#fff9c4", label="STVariable\nСимвол переменной/поля", tooltip="Символ переменной/поля"];
  "STArgument" [fillcolor="#fff9c4", label="STArgument\nСимвол аргумента", tooltip="Символ аргумента"];
  "PhysicalVariable" [fillcolor="#fff9c4", label="PhysicalVariable\nРантайм-значение\n(int/bool/массив/объект)", tooltip="Рантайм-значение (int/bool/массив/объект)"];
  "ScopeLayer" [fillcolor="#b2dfdb", label="ScopeLayer\nСлой области видимости\n(offset)", tooltip="Слой области видимости (offset)"];
  "ScopeLayerTree" [fillcolor="#b2dfdb", label="ScopeLayerTree\nДерево областей\nвидимости", tooltip="Дерево областей видимости"];
  "AddExpression" -> "ArithmeticExpression";
  "AllocExpression" -> "Expression";
  "AllocExpression" -> "Type";
  "ArithmeticExpression" -> "BinaryExpression";
  "Assert" -> "Expression";
  "Assert" -> "Statement";
  "BinaryExpression" -> "Expression";
  "ClassDeclaration" -> "Statement";
  "ClassDeclaration" -> "Visitor";
  "ClassDeclarationList" -> "ClassDeclaration";
  "ClassDeclarationList" -> "Statement";
  "ComparisonExpression" -> "BinaryExpression";
  "DeclarationList" -> "FieldDeclaration";
  "DeclarationList" -> "MethodDeclaration";
  "DeclarationList" -> "Statement";
  "DeclarationList" -> "Visitor";
  "DivExpression" -> "ArithmeticExpression";
  "EqualExpression" -> "BinaryExpression";
  "EqualExpression" -> "Expression";
  "ExecuteVisitor" -> "Elements";
  "ExecuteVisitor" -> "PhysicalVariable";
  "ExecuteVisitor" -> "Visitor";
  "Expression" -> "BaseElement";
  "Expression" -> "ScopeLayer";
  "ExpressionList" -> "Expression";
  "ExpressionList" -> "Statement";
  "FalseExpression" -> "Expression";
  "FieldDeclaration" -> "VarDeclaration";
  "FieldDeclaration" -> "Visitor";
  "FieldInvokeExpression" -> "Expression";
  "Formal" -> "BaseElement";
  "Formal" -> "Type";
  "Formal" -> "Visitor";
  "FormalsList" -> "BaseElement";
  "FormalsList" -> "Formal";
  "FormalsList" -> "Visitor";
  "GreaterExpression" -> "ComparisonExpression";
  "IdentExpression" -> "Expression";
  "IfElse" -> "Expression";
  "IfElse" -> "Statement";
  "IndexExpression" -> "Expression";
  "LengthExpression" -> "Expression";
  "LengthExpression" -> "FieldInvokeExpression";
  "LessExpression" -> "ComparisonExpression";
  "LocalVarDeclaration" -> "VarDeclaration";
  "LocalVarDeclaration" -> "Visitor";
  "LogicalAndExpression" -> "LogicalExpression";
  "LogicalExpression" -> "BinaryExpression";
  "LogicalOrExpression" -> "LogicalExpression";
  "MainClass" -> "Statement";
  "MainClass" -> "StatementList";
  "MainClass" -> "Visitor";
  "MethodDeclaration" -> "FormalsList";
  "MethodDeclaration" -> "Statement";
  "MethodDeclaration" -> "StatementList";
  "MethodDeclaration" -> "Type";
  "MethodDeclaration" -> "Visitor";
  "MethodInvocation" -> "Expression";
  "MethodInvocation" -> "ExpressionList";
  "MethodInvocation" -> "Statement";
  "ModExpression" -> "ArithmeticExpression";
  "MulExpression" -> "ArithmeticExpression";
  "NotExpression" -> "Expression";
  "NumExpression" -> "Expression";
  "PhysicalVariable" -> "ScopeLayer";
  "PhysicalVariable" -> "Type";
  "Print" -> "Expression";
  "Print" -> "Statement";
  "PrintVisitor" -> "Elements";
  "PrintVisitor" -> "Visitor";
  "Program" -> "ClassDeclaration";
  "Program" -> "Statement";
  "Return" -> "Expression";
  "Return" -> "Statement";
  "STArgument" -> "BaseSymbol";
  "STArgument" -> "Formal";
  "STClass" -> "BaseSymbol";
  "STClass" -> "ClassDeclaration";
  "STClass" -> "DeclarationList";
  "STClass" -> "FieldDeclaration";
  "STClass" -> "MethodDeclaration";
  "STClass" -> "STMethod";
  "STClass" -> "STVariable";
  "STMethod" -> "BaseSymbol";
  "STMethod" -> "FormalsList";
  "STMethod" -> "MethodDeclaration";
  "STMethod" -> "STArgument";
  "STMethod" -> "Type";
  "STVariable" -> "BaseSymbol";
  "STVariable" -> "Type";
  "STVariable" -> "VarDeclaration";
  "ScopeBlock" -> "Statement";
  "ScopeBlock" -> "StatementList";
  "ScopeBlock" -> "Visitor";
  "ScopeLayer" -> "BaseSymbol";
  "ScopeLayer" -> "FormalsList";
  "ScopeLayer" -> "MethodDeclaration";
  "ScopeLayer" -> "STClass";
  "ScopeLayer" -> "STMethod";
  "ScopeLayer" -> "STVariable";
  "ScopeLayerTree" -> "ScopeLayer";
  "Statement" -> "BaseElement";
  "StatementList" -> "Statement";
  "StatementList" -> "Visitor";
  "SubExpression" -> "ArithmeticExpression";
  "SymbolTreeVisitor" -> "Elements";
  "SymbolTreeVisitor" -> "ScopeLayer";
  "SymbolTreeVisitor" -> "ScopeLayerTree";
  "SymbolTreeVisitor" -> "Visitor";
  "ThisExpression" -> "Expression";
  "TrueExpression" -> "Expression";
  "VarAssignment" -> "Expression";
  "VarAssignment" -> "Statement";
  "VarDeclaration" -> "Statement";
  "VarDeclaration" -> "Type";
  "Visitor" -> "ForwardDeclaration";
  "While" -> "Expression";
  "While" -> "Statement";
  "driver" -> "ExecuteVisitor";
  "driver" -> "PrintVisitor";
  "driver" -> "SymbolTreeVisitor";
  "driver" -> "scanner";
  "main" -> "PrintVisitor";
  "main" -> "driver";
  "Elements" -> "Program" [style=dotted, color="#cfcfcf", label="агрегирует все\nузлы AST (42)", fontcolor="#9e9e9e", constraint=false];
  subgraph cluster_legend {
    label="Легенда (слои)"; fontsize=11; style="rounded,filled"; fillcolor="#fbfbfb"; color="#cccccc";
    "__lg1" [shape=box, style="rounded,filled", fillcolor="#ffe0b2", fontsize=9, label="Точки входа и\nинфраструктура"];
    "__lg2" [shape=box, style="rounded,filled", fillcolor="#e1bee7", fontsize=9, label="Базовые абстракции"];
    "__lg1" -> "__lg2" [style=invis];
    "__lg3" [shape=box, style="rounded,filled", fillcolor="#ffccbc", fontsize=9, label="Визиторы (проходы)"];
    "__lg2" -> "__lg3" [style=invis];
    "__lg4" [shape=box, style="rounded,filled", fillcolor="#c8e6c9", fontsize=9, label="Программа и классы"];
    "__lg3" -> "__lg4" [style=invis];
    "__lg5" [shape=box, style="rounded,filled", fillcolor="#bbdefb", fontsize=9, label="Операторы"];
    "__lg4" -> "__lg5" [style=invis];
    "__lg6" [shape=box, style="rounded,filled", fillcolor="#d7ccc8", fontsize=9, label="Выражения"];
    "__lg5" -> "__lg6" [style=invis];
    "__lg7" [shape=box, style="rounded,filled", fillcolor="#fff9c4", fontsize=9, label="Символы и типы"];
    "__lg6" -> "__lg7" [style=invis];
    "__lg8" [shape=box, style="rounded,filled", fillcolor="#b2dfdb", fontsize=9, label="Таблица символов"];
    "__lg7" -> "__lg8" [style=invis];
  }

  "AddExpression" -> "SubExpression" [style=invis, weight=12];
  "SubExpression" -> "MulExpression" [style=invis, weight=12];
  "MulExpression" -> "DivExpression" [style=invis, weight=12];
  "DivExpression" -> "ModExpression" [style=invis, weight=12];
  "LessExpression" -> "GreaterExpression" [style=invis, weight=12];
  "GreaterExpression" -> "EqualExpression" [style=invis, weight=12];
  "LogicalAndExpression" -> "LogicalOrExpression" [style=invis, weight=12];
  "NumExpression" -> "TrueExpression" [style=invis, weight=12];
  "TrueExpression" -> "FalseExpression" [style=invis, weight=12];
  "FalseExpression" -> "ThisExpression" [style=invis, weight=12];
  "ThisExpression" -> "IdentExpression" [style=invis, weight=12];
  "IndexExpression" -> "LengthExpression" [style=invis, weight=12];
  "LengthExpression" -> "FieldInvokeExpression" [style=invis, weight=12];
  "FieldInvokeExpression" -> "AllocExpression" [style=invis, weight=12];
  "AllocExpression" -> "NotExpression" [style=invis, weight=12];
  "VarAssignment" -> "IfElse" [style=invis, weight=12];
  "IfElse" -> "While" [style=invis, weight=12];
  "While" -> "Print" [style=invis, weight=12];
  "Return" -> "Assert" [style=invis, weight=12];
  "Assert" -> "ScopeBlock" [style=invis, weight=12];
  "ScopeBlock" -> "MethodInvocation" [style=invis, weight=12];
  "STClass" -> "STMethod" [style=invis, weight=12];
  "STMethod" -> "STVariable" [style=invis, weight=12];
  "STVariable" -> "STArgument" [style=invis, weight=12];
}

class Test {
    public static void main() {
        Counter c;
        c = new Counter();
        c.init();
        System.out.println(c.getValue());
        System.out.println(c.inc());
        System.out.println(c.inc());
        System.out.println(c.getValue());
    }
}

class Counter {
    int value;
    public int init() {
        this.value = 1;
    }
    public int inc() {
        this.value = this.value + 1;
        return this.value;
    }
    public int getValue() {
        return this.value;
    }
}

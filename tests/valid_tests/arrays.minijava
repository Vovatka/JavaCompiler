class Test {
    public static void main() {
        int[] arr; int i; int sum;
        arr = new int[5];
        i = 0;
        while (i < 5) {
            arr[i] = i * 2;
            i = i + 1;
        }
        sum = 0;
        i = 0;
        while (i < 5) {
            sum = sum + arr[i];
            i = i + 1;
        }
        System.out.println(sum);
    }
}
